    public static void sumOfTwoElementInArrayIsTarget(int[] nums, int target){
          int n = nums.length;
           ArrayList<Integer> result = new ArrayList<>();
        // Finding all possible pairs
        for (int i = 0; i < n; i++) {
            for (int j = i + 1; j < n; j++) {
                int sum = nums[i] + nums[j];
                if (sum == target) {
                    result.add(i); 
                    result.add(j);
                }
            }
            
        }
         for (int num : result) {
            System.out.print(num + " ");
        }
        System.out.println();
    }
    
