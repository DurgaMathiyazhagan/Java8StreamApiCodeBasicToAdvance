    public static void linkedHahMapAppUniqueCharInString(String str){ 
        if(str==null || str.isEmpty()){
            System.out.println("Null/Empty String");
        }
        
        // LinkedHashMap maintains the insertion order of characters
        Map<Character,Integer> map = new LinkedHashMap<>();
        
        for(char c: str.toCharArray()){
            map.put(c,map.getOrDefault(c,0)+1);
        }
        
         // Step 2: Iterate through the map to find the first character with a count of 1
        for (Map.Entry<Character, Integer> entry : map.entrySet()) {
            if (entry.getValue() == 1) {
                System.out.println( entry.getKey());
                break;
            }
        }
        
        for (Map.Entry<Character, Integer> entry : map.entrySet()) {
            if (entry.getValue() >1) {
                System.out.println("Duplicated Numbers"+ entry.getKey());
            }
        }
    } 
    
    
    public static void hashMapAppcountFrequency(Map<Integer,Integer> map, int[] arr){ 
       for(int num : arr ){
           map.put(num, map.getOrDefault(num,0)+1);
       }
       map.forEach((key,val) -> System.out.println(key + "->" + val));
        // Using HashMap Time Complexity Expected: O(n)
    } 
